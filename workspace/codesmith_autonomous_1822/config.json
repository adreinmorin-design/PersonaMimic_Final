{
  "copyright": {
    "year": 2023,
    "holder": "Dre Proprietary"
  },
  "projectName": "codesmith_autonomous_1822",
  "toolDescription": "High-performance tool for Autonomous Data-Sovereignty Audit for Solo AI SaaS",
  "version": "1.0.0",
  "dependencies": {
    "pythonVersion": "3.9+",
    "requiredLibraries": [
      "pandas>=1.4.0",
      "numpy>=1.21.0",
      "requests>=2.26.0",
      "flask>=2.0.0",
      "logging>=0.5.1"
    ]
  },
  "configurationSettings": {
    "auditFrequency": {
      "default": "daily",
      "options": ["hourly", "daily", "weekly"]
    },
    "dataRetentionPeriod": {
      "default": 365,
      "unit": "days"
    },
    "logLevel": {
      "default": "INFO",
      "options": ["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"]
    },
    "emailNotifications": {
      "enabled": true,
      "smtpServer": "smtp.example.com",
      "port": 587,
      "username": "",
      "password": ""
    }
  },
  "dataSources": [
    {
      "name": "userActivityLogs",
      "type": "csv",
      "path": "/var/log/user_activity.csv"
    },
    {
      "name": "systemMetrics",
      "type": "json",
      "path": "/var/log/system_metrics.json"
    }
  ],
  "auditRules": [
    {
      "ruleName": "dataAccessFrequency",
      "description": "Audit data access frequency to ensure compliance with data sovereignty policies.",
      "criteria": {
        "minAccessesPerDay": 5,
        "maxAccessesPerDay": 100
      }
    },
    {
      "ruleName": "dataRetentionPolicy",
      "description": "Ensure that data is retained for the minimum required period as per policy.",
      "criteria": {
        "retentionPeriod": 365
      }
    }
  ],
  "loggingConfig": {
    "fileHandler": {
      "filename": "/var/log/audit.log",
      "level": "INFO",
      "formatter": "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
    },
    "consoleHandler": {
      "level": "DEBUG",
      "formatter": "%(asctime)s - %(levelname)s - %(message)s"
    }
  },
  "apiEndpoints": [
    {
      "path": "/audit/start",
      "method": "POST",
      "description": "Start a new audit session."
    },
    {
      "path": "/audit/status",
      "method": "GET",
      "description": "Get the status of the current audit session."
    }
  ]
}