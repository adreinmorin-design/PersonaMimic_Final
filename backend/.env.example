# --- PersonaMimic 100% Free & Open Source Configuration ---

# Model Configuration (Standard OSS Models)
CURRENT_MODEL=llama-3.1-8b-instant
OLLAMA_HOST=http://127.0.0.1:11434

# Optional: Free Cloud Fallback (serves OSS Models)
# Visit groq.com for a free API key
GROQ_API_KEY=
OLLAMA_CLOUD_URL=https://api.groq.com/openai/v1
OLLAMA_CLOUD_KEY=

# Voice Configuration (Free Neural Voices)
# edge-tts is built-in and requires no keys.
# Example voices: en-US-AndrewNeural, en-US-AvaNeural
DEFAULT_VOICE=en-US-AndrewNeural

# Infrastructure
DATABASE_URL=sqlite:///./persona_mimic.db
REDIS_URL=redis://localhost:6379/0
ENVIRONMENT=development

# Optional: SaaS Observability (Strictly Opt-in)
# Leave blank for 100% local operation
SENTRY_DSN=
LOGFIRE_TOKEN=

# Platform API Keys (Building for free distribution)
WHOP_API_KEY=
WHOP_COMPANY_ID=
GUMROAD_API_KEY=
STRIPE_API_KEY=

# Security
SECURITY_KEY=dre_secure_2026
